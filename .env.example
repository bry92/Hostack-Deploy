# Hostack environment example
#
# This app expects the frontend and /api auth routes to share the same public origin.
# Auth0 should be configured against your public app origin, not a separate API host.
#
# With APP_URL=http://localhost:3000, use these Auth0 settings:
# Allowed Callback URLs: http://localhost:3000/api/callback
# Allowed Logout URLs: http://localhost:3000
# Allowed Web Origins: http://localhost:3000
#
# Production example with APP_URL=https://app.example.com:
# Allowed Callback URLs: https://app.example.com/api/callback
# Allowed Logout URLs: https://app.example.com
# Allowed Web Origins: https://app.example.com

# Shared app origin used in notifications and auth-related links
APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_PORT=3000
API_PORT=3001
FRONTEND_PORT=5173

# API server
# PORT is only needed when running the API directly without the local dev proxy.
# `pnpm run dev` injects API_PORT/FRONTEND_PORT for you.
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hostack
SECRET_ENCRYPTION_KEY=
# 32-byte key encoded as base64 or 64 hex chars.
# Example PowerShell generator:
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=https://api.hostack.local
AUTH0_SCOPE=openid profile email offline_access
AUTH0_PROMPT=login

# Generic OIDC equivalents, if you prefer provider-neutral names instead of Auth0 aliases
# OIDC_ISSUER_URL=https://your-tenant.us.auth0.com
# OIDC_CLIENT_ID=your-auth0-client-id
# OIDC_CLIENT_SECRET=your-auth0-client-secret
# OIDC_CLIENT_AUTH_METHOD=client_secret_basic
# OIDC_AUDIENCE=https://api.hostack.local
# OIDC_SCOPE=openid profile email offline_access
# OIDC_PROMPT=login

# Frontend
# If you run the Vite frontend separately, it still expects to be served from the same public origin
# as /api for auth redirects. In practice that usually means a reverse proxy in front of both services.
BASE_PATH=/
ENABLE_WORKSPACE_DEVTOOLS=false

# Optional AI integration
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
